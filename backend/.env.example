# LLM: hf_local = Hugging Face model files under backend/data/hf_hub (default, no Ollama).
#       ollama = use Ollama HTTP API (OLLAMA_* below).
LLM_BACKEND=hf_local
HF_LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# Prompt truncation + reply length (smaller = faster on CPU)
HF_CONTEXT_TOKENS=2048
HF_MAX_NEW_TOKENS=384
# HF_DO_SAMPLE=true
# HF_TEMPERATURE=0.7
# HF_TOP_P=0.9
# HF_TRUST_REMOTE_CODE=false
# Optional for gated models:
# HF_TOKEN=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Retrieval: cross-encoder rerank after BM25+vector fusion (~90MB download on first use)
# RERANK_ENABLED=false
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_POOL_MULTIPLIER=4

# PDF ingest: full-page OCR for scan-heavy / low-text PDFs (requires tesseract on PATH)
# PDF_OCR_PAGES_ENABLED=true
# PDF_OCR_MAX_PAGES=80
# PDF_OCR_DPI_SCALE=2.0

# Optional: Ollama vision model for figure captions at ingest (e.g. llava, llama3.2-vision)
# OLLAMA_VISION_MODEL=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: http://127.0.0.1:8000 — used in Markdown export for figure URLs
API_PUBLIC_URL=
